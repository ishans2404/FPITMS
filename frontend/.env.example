# Copy this file to .env and fill in your project's values.
#
# SECURITY: only put the URL and PUBLISHABLE (or anon) key here. Vite inlines
# every VITE_-prefixed variable into the browser bundle. The service role key
# must NEVER be prefixed with VITE_ or live in this file — it bypasses RLS
# entirely. Phase 1 has no server-side code that needs it.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx
